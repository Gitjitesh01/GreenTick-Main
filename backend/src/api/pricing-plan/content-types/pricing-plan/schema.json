{
  "kind": "collectionType",
  "collectionName": "pricing_plans",
  "info": {
    "singularName": "pricing-plan",
    "pluralName": "pricing-plans",
    "displayName": "Pricing Plan"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "buttonText": {
      "type": "string"
    },
    "buttonLink": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer"
    },
    "features": {
      "type": "component",
      "component": "shared.feature-item",
      "repeatable": true
    },
    "borderHighlight": {
      "type": "boolean"
    },
    "monthlyPrice": {
      "type": "decimal"
    },
    "yearlyPrice": {
      "type": "decimal"
    },
    "currency": {
      "type": "enumeration",
      "enum": [
        "INR (₹)",
        "USD ($)"
      ]
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "planType": {
      "type": "enumeration",
      "enum": [
        "starter",
        "growth",
        "business",
        "enterprise"
      ]
    }
  }
}
