{
  "kind": "collectionType",
  "collectionName": "newsletter_subscribers",
  "info": {
    "singularName": "newsletter-subscriber",
    "pluralName": "newsletter-subscribers",
    "displayName": "Newsletter Subscriber"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true
    },
    "statusOfSubscriber": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "subscribed",
        "unsubscribed",
        "pending"
      ]
    },
    "subscribedAt": {
      "type": "datetime",
      "required": true
    },
    "source": {
      "type": "text"
    },
    "verified": {
      "type": "boolean"
    }
  }
}
