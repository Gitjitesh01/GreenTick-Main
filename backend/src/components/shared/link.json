{
  "collectionName": "components_shared_links",
  "info": {
    "displayName": "Link"
  },
  "options": {},
  "attributes": {
    "href": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "nav_description": {
      "type": "string"
    },
    "isExternal": {
      "type": "boolean",
      "default": false
    },
    "isButtonLink": {
      "type": "boolean",
      "default": false
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "PRIMARY",
        "SECONDARY"
      ]
    },
    "isDropdown": {
      "type": "boolean",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": ""
            },
            ""
          ]
        }
      },
      "required": false,
      "default": false
    },
    "dropdownItems": {
      "type": "component",
      "component": "shared.dropdown-item",
      "repeatable": true
    },
    "menuDetail": {
      "type": "component",
      "component": "shared.menu-detail",
      "repeatable": true
    }
  },
  "config": {}
}
